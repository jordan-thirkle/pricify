---
import '../styles/global.css';
export interface Props {
  title?: string;
  description?: string;
}
const { title = 'Pricify — SaaS Monetization Toolkit', description = 'Free tools to price, monetize, and grow your SaaS. Built for indie makers and solo founders.' } = Astro.props;
---

<!doctype html>
<html lang="en" class="dark scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <title>{title}</title>
    <meta name="twitter:card" content="summary_large_image" />
    <script type="application/ld+json">{"@context":"https://schema.org","@type":"WebApplication","name":"Pricify","url":"https://mvp-pricify.vercel.app","description":"Free SaaS monetization toolkit with pricing calculator, freemium analyzer, metrics dashboard, and Stripe link generator.","applicationCategory":"BusinessApplication","operatingSystem":"All","offers":{"@type":"Offer","price":"0","priceCurrency":"USD"}}</script>
    <script defer data-domain="pricify.vercel.app" src="https://plausible.io/js/script.js"></script>
  </head>
  <body class="min-h-screen flex flex-col">
    <slot />
  </body>
</html>
